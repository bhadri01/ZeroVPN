# syntax=docker/dockerfile:1.7
FROM node:24-alpine AS build
WORKDIR /app
# Pin pnpm to 9.15.x — pnpm 10 introduced ERR_PNPM_IGNORED_BUILDS for any
# package with a postinstall script (esbuild, msw) and treats it as a hard
# error during `--frozen-lockfile`. The `onlyBuiltDependencies` opt-in is
# unreliable in CI image builds. Pinning to pnpm 9 keeps the lockfile schema
# compatible (no v10-only features in our lockfile) without the new gate.
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate
COPY web/package.json web/pnpm-lock.yaml* web/.npmrc* ./
RUN pnpm install --frozen-lockfile || pnpm install --no-frozen-lockfile
COPY web/ ./
RUN pnpm build

FROM nginx:1.28-alpine AS runtime
RUN rm /etc/nginx/conf.d/default.conf
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
# Use 127.0.0.1 explicitly — Alpine's wget resolves `localhost` to ::1 first
# and nginx only listens on IPv4 by default, so the healthcheck would fail.
HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
    CMD wget -qO- http://127.0.0.1/healthz || exit 1
CMD ["nginx", "-g", "daemon off;"]
