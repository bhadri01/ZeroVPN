.:53 {
  errors
  log
  # Per-peer *.vpn.local names from the hosts file the API regenerates on every
  # DNS change (routes/dns.rs::sync_dnsmasq). Poll the file every 1s and serve
  # short-TTL records so added/removed names reflect within ~1-2s. `fallthrough`
  # lets non-matching names continue to the forwarder below.
  hosts /etc/dnsmasq.d/zerovpn-peers.conf {
    reload 1s
    ttl 5
    fallthrough
  }
  forward . 1.1.1.1 1.0.0.1
  # Cache upstream answers, but keep negative (NXDOMAIN) caching short: a name
  # queried just before it was added must not stay NXDOMAIN for long. Capacity
  # 1500, max negative TTL 2s.
  cache 30 {
    denial 1500 2
  }
}
