# ZeroVPN configuration.
#
#   cp .env.example .env && ./scripts/init-secrets.sh   # fills the CHANGEME values
#
# Ships dev defaults. For production, change: ENVIRONMENT, DOMAIN/PUBLIC_URL,
# CERT_RESOLVER=le, ACME_EMAIL, the SMTP block, WG__SERVER_ENDPOINT, and
# REGISTRY/IMAGE_TAG — then re-run init-secrets.sh. Full guide: docs/runbook.md.
#
# Internal wiring (HTTP bind, ZeroMQ, WG interface/port/backend) is set by the
# compose file and has code defaults, so it is intentionally NOT listed here.

# ── Core ────────────────────────────────────────────────────────────────────
# dev | staging | production. `production` refuses CHANGEME secrets, requires a
# non-localhost domain, and sets Secure cookies.
ZEROVPN_ENVIRONMENT=dev
ZEROVPN_DOMAIN=localhost
ZEROVPN_PUBLIC_URL=http://localhost

# ── TLS (Traefik) ───────────────────────────────────────────────────────────
# CERT_RESOLVER empty = Traefik self-signed cert (dev). `le` = Let's Encrypt for
# ZEROVPN_DOMAIN (prod; the domain must already resolve to this host). ACME_EMAIL
# receives expiry notices and is only used when CERT_RESOLVER=le.
ZEROVPN_CERT_RESOLVER=
ZEROVPN_ACME_EMAIL=admin@localhost

# ── Secrets (init-secrets.sh fills the CHANGEME values) ─────────────────────
# Rotating ZEROVPN_KEK without a re-encryption migration breaks 2FA for every
# user — keep an off-box copy.
ZEROVPN_DATABASE_URL=postgres://zerovpn:CHANGEME@db:5432/zerovpn?sslmode=disable
ZEROVPN_SESSION_SECRET=CHANGEME
ZEROVPN_KEK=CHANGEME

# Sign-in idle window in minutes — every authenticated request refreshes it,
# so this is "signed out after N minutes of no activity", not an absolute
# cap. Unset = 10080 (7 days) in production, 43200 (30 days) in dev.
# ZEROVPN_SESSION_IDLE_MINUTES=10080

# ── Container images (prod pulls these; `make up` builds locally) ───────────
# `make images && make push` publishes them; `make up-prod` pulls. See runbook.
# Builds target linux/amd64 (the deploy hosts' arch) even on an ARM Mac.
# Uncomment for fast native-arch images when only building for local `make up`:
# ZEROVPN_BUILD_PLATFORM=linux/arm64
ZEROVPN_REGISTRY=ghcr.io/bhadri01
ZEROVPN_IMAGE_TAG=latest

# ── Mail (SMTP) ─────────────────────────────────────────────────────────────
# DEV → leave HOST empty: the API logs verification / reset links instead of
#       sending (watch `make logs-dev`). To catch real mail locally, layer
#       `-f docker-compose.mail.yml` (MailHog, UI at http://localhost:8025)
#       into the dev compose and set HOST=mailhog / PORT=1025.
# PROD → a real relay. Register/resend/forgot are rate-limited per address
#       and per client IP to protect the relay's quota.
#   HOST / PORT            the SMTP server and port.
#   USERNAME / PASSWORD    the SMTP-AUTH credentials — auth is sent when both set.
#   FROM                   the From address on outgoing mail.
#   SSL_TLS=true           implicit TLS from byte 1 (SMTPS, usually port 465).
#   STARTTLS=true          upgrade a plaintext connection via STARTTLS (usually 587).
#                          SSL_TLS wins if both are true; both false = no encryption.
#   VALIDATE_CERTS=true    verify the server's TLS certificate. Keep true; set
#                          false ONLY for an internal relay with a self-signed cert.
# Gmail: HOST=smtp.gmail.com PORT=587 STARTTLS=true SSL_TLS=false,
#        USERNAME=you@domain, PASSWORD=<a Google App Password>, FROM=<same address>.
ZEROVPN_SMTP__HOST=
ZEROVPN_SMTP__PORT=1025
ZEROVPN_SMTP__USERNAME=
ZEROVPN_SMTP__PASSWORD=
ZEROVPN_SMTP__FROM=ZeroVPN <noreply@localhost>
ZEROVPN_SMTP__STARTTLS=false
ZEROVPN_SMTP__SSL_TLS=false
ZEROVPN_SMTP__VALIDATE_CERTS=true

# ── WireGuard ───────────────────────────────────────────────────────────────
# Public UDP endpoint peers dial (baked into each device .conf). Prod: set to
# <your-domain>:51820. WG runs userspace in the compose — nothing to install on
# the host, and the backend/interface/port are compose-managed.
ZEROVPN_WG__SERVER_ENDPOINT=localhost:51820
# Optional: static IP of the CoreDNS container to DNAT peer DNS to (enables
# *.vpn.local). Blank = off. Only set (e.g. 172.30.0.53) after confirming CoreDNS
# is reachable from the WG host — a wrong value black-holes ALL peer DNS.
ZEROVPN_WG__DNS_FORWARD_IP=

# ── Logging (quieter in prod: info,zerovpn=info) ────────────────────────────
RUST_LOG=info,zerovpn=debug

# ── Google OAuth (optional) ─────────────────────────────────────────────────
# All three required to show "Continue with Google"; omit any and the routes
# return 503. REDIRECT_URL must EXACTLY match the Google Cloud Console entry.
ZEROVPN_GOOGLE_OAUTH__CLIENT_ID=
ZEROVPN_GOOGLE_OAUTH__CLIENT_SECRET=
ZEROVPN_GOOGLE_OAUTH__REDIRECT_URL=

# ── Data retention (optional) ───────────────────────────────────────────────
# Each operational table purges on its own window (default 30d; 730d for daily
# candles). Override per table with ZEROVPN_<TABLE>_RETENTION_DAYS=N (0 = keep
# forever). Full list of table names: docs/runbook.md → "Stats pipeline".
