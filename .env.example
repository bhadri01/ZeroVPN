# ZeroVPN environment configuration.
#
#   cp .env.example .env
#   ./scripts/init-secrets.sh            # fills CHANGEME values + writes secrets/*.txt
#
# This file ships dev-shaped defaults. Going to production:
#   1. Set ZEROVPN_ENVIRONMENT=production
#   2. Set ZEROVPN_DOMAIN to your real hostname + ZEROVPN_PUBLIC_URL=https://<that>
#   3. Set ZEROVPN_ACME_EMAIL
#   4. Set ZEROVPN_CERT_RESOLVER=le (Traefik provisions a Let's Encrypt cert)
#   5. Point ZEROVPN_SMTP__HOST at a real relay (not mailhog)
#   6. Set ZEROVPN_WG__BACKEND=kernel and ZEROVPN_WG__SERVER_ENDPOINT=<domain>:51820
#   7. Quieter logs: RUST_LOG=info,zerovpn=info, ZEROVPN_LOG_LEVEL=info
#   8. Re-run ./scripts/init-secrets.sh so prod secrets aren't the dev values

# Environment: dev | staging | production. The api enforces extra checks
# when set to `production` (refuses CHANGEME secrets, requires non-localhost
# domain, sets Secure cookies).
ZEROVPN_ENVIRONMENT=dev

# Public hostname + URL.
ZEROVPN_DOMAIN=localhost
ZEROVPN_PUBLIC_URL=http://localhost

# ACME contact email — used by Let's Encrypt for rate-limit / expiry notices.
# Used only when ZEROVPN_CERT_RESOLVER=le; ignored for the dev self-signed cert.
ZEROVPN_ACME_EMAIL=admin@localhost

# TLS cert resolver for Traefik's `websecure` (:443) entrypoint. Empty in dev
# → Traefik serves its self-signed default cert (no ACME, avoids Let's Encrypt
# rate limits on localhost). Set to `le` in prod → a Let's Encrypt cert for
# ZEROVPN_DOMAIN (which must already resolve to this host).
ZEROVPN_CERT_RESOLVER=

# Backend HTTP bind (inside the container). Traefik is the only thing that
# talks to this; never expose 8080 publicly.
ZEROVPN_BIND_ADDRESS=0.0.0.0:8080

# Postgres + Redis (inside the docker network). init-secrets.sh fills the
# CHANGEME password.
ZEROVPN_DATABASE_URL=postgres://zerovpn:CHANGEME@db:5432/zerovpn?sslmode=disable
ZEROVPN_REDIS_URL=redis://:CHANGEME@redis:6379

# 32-byte base64 secrets. init-secrets.sh fills these.
# Rotating ZEROVPN_KEK without a re-encryption migration breaks 2FA for
# every user — keep an off-box copy.
ZEROVPN_SESSION_SECRET=CHANGEME
ZEROVPN_KEK=CHANGEME

# SMTP. Dev points at MailHog (brought up via the `dev` profile; web UI at
# http://localhost:8025). Prod: external relay (Postmark, SES, postfix).
# STARTTLS is required when port != 1025.
ZEROVPN_SMTP__HOST=mailhog
ZEROVPN_SMTP__PORT=1025
ZEROVPN_SMTP__USERNAME=
ZEROVPN_SMTP__PASSWORD=
ZEROVPN_SMTP__FROM=ZeroVPN <noreply@localhost>

# WireGuard.
#   noop   — peers tracked in the DB but no real WG interface (dev/macOS).
#   shell  — shells out to `wg set` against a running interface.
#   kernel — drives peers via netlink/UAPI (Linux + kernel module). Prod default.
ZEROVPN_WG__INTERFACE=wg0
ZEROVPN_WG__SERVER_ENDPOINT=localhost:51820
ZEROVPN_WG__LISTEN_PORT=51820
ZEROVPN_WG__CONTROL_SOCKET=/run/wg/control.sock
ZEROVPN_WG__DNSMASQ_HOSTS_FILE=/etc/dnsmasq.d/zerovpn-peers.conf
# Resolver the wg0 PostUp DNATs peer DNS to (the `dnsmasq`/CoreDNS
# container's static IP on the backend network). Peers are handed the
# tunnel gateway as DNS; this forwards those queries to CoreDNS so
# *.vpn.local resolves.
#
# DISABLED by default: if CoreDNS isn't reachable at this IP from the WG
# host, the DNAT black-holes ALL DNS and breaks internet access. Set it
# (e.g. 172.30.0.53) only after verifying reachability. Blank = no DNAT.
ZEROVPN_WG__DNS_FORWARD_IP=
ZEROVPN_WG__BACKEND=noop

# ZeroMQ (worker binds, api connects). Internal to the docker network.
ZEROVPN_EVENTS__PUBLISHER_BIND=tcp://0.0.0.0:5555
ZEROVPN_EVENTS__SUBSCRIBER_CONNECT=tcp://worker:5555

# Stats pipeline. Cadence is the worker poll interval (also the WS push rate).
ZEROVPN_STATS_INTERVAL_SECS=1
#
# Data retention. Each operational table is purged on its own window. Unset
# = the built-in default (30 days for every table below except daily candle
# rollups, which default to 730). Set a value in days to change the window,
# or 0 to disable the purge and keep that table forever. See
# docs/runbook.md → "Stats pipeline & disk growth".
# ZEROVPN_SAMPLE_RETENTION_DAYS=30          # raw per-device bandwidth_samples
# ZEROVPN_SERVER_SAMPLE_RETENTION_DAYS=30   # per-host server_samples
# ZEROVPN_DEST_RETENTION_DAYS=30            # flow metadata (destination_ips)
# ZEROVPN_AUDIT_RETENTION_DAYS=30           # audit_logs (set 0 for a no-TTL audit trail)
# ZEROVPN_FAILED_LOGIN_RETENTION_DAYS=30    # failed_logins
# ZEROVPN_CANDLE_MINUTE_RETENTION_DAYS=30   # 1-minute OHLC candles
# ZEROVPN_CANDLE_DAILY_RETENTION_DAYS=730   # daily OHLC candle rollups

# Logging — verbose in dev. Tune down for prod (RUST_LOG=info,zerovpn=info).
RUST_LOG=info,zerovpn=debug
ZEROVPN_LOG_LEVEL=debug

# Google OAuth 2.0 (optional). All three values are required to enable
# "Continue with Google" on the login screen — omit any one and the
# /auth/google/* routes return 503 instead. The redirect URL must match
# *exactly* what's registered in Google Cloud Console for the OAuth
# client (scheme, host, port, path) including the dev port.
ZEROVPN_GOOGLE_OAUTH__CLIENT_ID=
ZEROVPN_GOOGLE_OAUTH__CLIENT_SECRET=
ZEROVPN_GOOGLE_OAUTH__REDIRECT_URL=
