# Production environment template.
# Copy to .env.prod and edit the REPLACE_WITH_* placeholders, then run
# `./scripts/init-secrets.sh prod` to fill in random secrets.
#
#   cp .env.prod.example .env.prod
#   $EDITOR .env.prod                   # set ZEROVPN_DOMAIN + SMTP relay
#   ./scripts/init-secrets.sh prod
#
# `make up-prod` (or `make up ENV=prod`) uses this file.

# Environment marker — the api binary enforces extra checks when this is set
# to `production`: refuses to boot with default secrets or localhost domain;
# session cookies get the Secure flag.
ZEROVPN_ENVIRONMENT=production

# Real domain. Caddy provisions a Let's Encrypt cert against this hostname.
# Must resolve to this host before the stack boots, or LE issuance fails.
ZEROVPN_DOMAIN=REPLACE_WITH_YOUR_DOMAIN
ZEROVPN_PUBLIC_URL=https://REPLACE_WITH_YOUR_DOMAIN

# ACME contact email — required by some CAs and used by LE to notify on
# expiry / rate-limit issues.
ZEROVPN_ACME_EMAIL=admin@REPLACE_WITH_YOUR_DOMAIN

# Backend HTTP bind (inside the container). Caddy is the only thing that
# talks to this; never expose 8080 publicly.
ZEROVPN_BIND_ADDRESS=0.0.0.0:8080

# Postgres connection (inside the docker network)
ZEROVPN_DATABASE_URL=postgres://zerovpn:CHANGEME@db:5432/zerovpn?sslmode=disable

# Redis connection
ZEROVPN_REDIS_URL=redis://:CHANGEME@redis:6379

# 32-byte random secret for tower-sessions (base64). init-secrets.sh fills this.
# Never reuse the dev value; the prod boot check rejects CHANGEME / dev defaults.
ZEROVPN_SESSION_SECRET=CHANGEME

# 32-byte random KEK (base64). Encrypts TOTP secrets and WG pre-shared keys
# at rest. **Rotating this without a re-encryption migration breaks 2FA for
# every user.** Keep an off-box copy.
ZEROVPN_KEK=CHANGEME

# SMTP relay. MailHog is dev-only; in prod point at a real outbound relay
# (Postmark, SES, your own postfix, etc.). STARTTLS is required when port != 1025.
ZEROVPN_SMTP__HOST=smtp.REPLACE_WITH_YOUR_DOMAIN
ZEROVPN_SMTP__PORT=587
ZEROVPN_SMTP__USERNAME=
ZEROVPN_SMTP__PASSWORD=
ZEROVPN_SMTP__FROM=ZeroVPN <noreply@REPLACE_WITH_YOUR_DOMAIN>

# WireGuard. `shell` calls `wg set` against the running kernel interface;
# requires the wg container running (`docker compose --profile wg up -d`).
ZEROVPN_WG__INTERFACE=wg0
ZEROVPN_WG__SERVER_ENDPOINT=REPLACE_WITH_YOUR_DOMAIN:51820
ZEROVPN_WG__LISTEN_PORT=51820
ZEROVPN_WG__CONTROL_SOCKET=/run/wg/control.sock
ZEROVPN_WG__DNSMASQ_HOSTS_FILE=/etc/dnsmasq.d/zerovpn-peers.conf
ZEROVPN_WG__BACKEND=shell

# ZeroMQ (worker binds, api connects). Internal to the docker network only.
ZEROVPN_EVENTS__PUBLISHER_BIND=tcp://0.0.0.0:5555
ZEROVPN_EVENTS__SUBSCRIBER_CONNECT=tcp://worker:5555

# Logging — quieter in prod. JSON logs hit stdout; Loki/Promtail (if enabled)
# pick them up via the docker SD.
RUST_LOG=info,zerovpn=info
ZEROVPN_LOG_LEVEL=info

# Backup: age public-key recipient. If set, the offen/docker-volume-backup
# container encrypts the nightly tarball to this key.
ZEROVPN_BACKUP_AGE_RECIPIENT=
