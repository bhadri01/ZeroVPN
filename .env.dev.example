# Development environment template.
# Copy to .env.dev and run `./scripts/init-secrets.sh dev` to fill in secrets.
#
#   cp .env.dev.example .env.dev
#   ./scripts/init-secrets.sh dev
#
# `make up` / `make setup` use this file.

# Environment: dev | staging | production. Drives prod-only safety checks in
# the api binary (refuses to boot with weak secrets or localhost domain).
ZEROVPN_ENVIRONMENT=dev

# Public domain for the deployment. Dev uses localhost; Caddy serves over
# self-signed certs from its internal CA.
ZEROVPN_DOMAIN=localhost
ZEROVPN_PUBLIC_URL=http://localhost

# Backend HTTP bind (inside the container)
ZEROVPN_BIND_ADDRESS=0.0.0.0:8080

# Postgres connection (inside the docker network)
ZEROVPN_DATABASE_URL=postgres://zerovpn:CHANGEME@db:5432/zerovpn?sslmode=disable

# Redis connection
ZEROVPN_REDIS_URL=redis://:CHANGEME@redis:6379

# 32-byte random secret for tower-sessions (base64). init-secrets.sh fills this.
ZEROVPN_SESSION_SECRET=CHANGEME

# 32-byte random KEK (base64). Encrypts TOTP secrets and WG pre-shared keys at rest.
ZEROVPN_KEK=CHANGEME

# SMTP (dev: MailHog catches mail at http://localhost:8025)
ZEROVPN_SMTP__HOST=mailhog
ZEROVPN_SMTP__PORT=1025
ZEROVPN_SMTP__USERNAME=
ZEROVPN_SMTP__PASSWORD=
ZEROVPN_SMTP__FROM=ZeroVPN <noreply@localhost>

# WireGuard. `noop` backend in dev — peers are tracked in the DB but no real
# WG interface is touched. Flip to `shell` only when running under
# `--profile wg` with a Linux host that has the kernel module.
ZEROVPN_WG__INTERFACE=wg0
ZEROVPN_WG__SERVER_ENDPOINT=localhost:51820
ZEROVPN_WG__LISTEN_PORT=51820
ZEROVPN_WG__CONTROL_SOCKET=/run/wg/control.sock
ZEROVPN_WG__DNSMASQ_HOSTS_FILE=/etc/dnsmasq.d/zerovpn-peers.conf
ZEROVPN_WG__BACKEND=noop

# ZeroMQ (worker binds, api connects)
ZEROVPN_EVENTS__PUBLISHER_BIND=tcp://0.0.0.0:5555
ZEROVPN_EVENTS__SUBSCRIBER_CONNECT=tcp://worker:5555

# Logging — verbose in dev
RUST_LOG=info,zerovpn=debug
ZEROVPN_LOG_LEVEL=debug

# Stats pipeline. Cadence is the worker poll interval (also the WS push
# rate). Retention windows: when unset, samples are kept forever
# ("trading-style every-tick"). Set to e.g. 30 to bring back a hard window.
# See docs/runbook.md → "Disk growth".
# ZEROVPN_STATS_INTERVAL_SECS=1
# ZEROVPN_SAMPLE_RETENTION_DAYS=
# ZEROVPN_SERVER_SAMPLE_RETENTION_DAYS=
